{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/core-api/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "plugins": [
      {
        "name": "@nestjs/swagger/plugin",
        "options": {
          "classValidatorShim": true,
          "dtoFileNameSuffix": ["-dto.ts", ".entity.ts"]
        }
      }
    ],
    "webpack": true,
    "tsConfigPath": "apps/core-api/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/core-api",
  "projects": {
    "notifications-gateway": {
      "type": "application",
      "root": "apps/notifications-gateway",
      "entryFile": "main",
      "sourceRoot": "apps/notifications-gateway/src",
      "compilerOptions": {
        "tsConfigPath": "apps/notifications-gateway/tsconfig.app.json"
      }
    },
    "core-api": {
      "type": "application",
      "root": "apps/core-api",
      "entryFile": "main",
      "sourceRoot": "apps/core-api/src",
      "compilerOptions": {
        "tsConfigPath": "apps/core-api/tsconfig.app.json"
      }
    }
  }
}
