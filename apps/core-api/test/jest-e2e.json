{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testRegex": "test/.*\\.e2e-spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@core-api/(.*)$": "<rootDir>/src/$1",
    "^@notifications-gateway/(.*)$": "<rootDir>/../notifications-gateway/src/$1",
    "^@contracts/(.*)$": "<rootDir>/../../libs/contracts/src/$1"
  },
  "testEnvironment": "node"
}
