PORT=3001
NODE_ENV=development
SERVICE_NAME=core-api
LOG_LEVEL=info
LOG_PRETTY=true
CONTAINERIZED=false
METRICS_PATH=/metrics

JWT_SECRET=replace_me
REFRESH_TOKEN_HASH_SECRET=replace_me
SALT_ROUNDS=10

DB_HOST=localhost
DB_PORT=5430
DB_USER=root
DB_PASSWORD=root
DB_NAME=db
DB_SYNCHRONIZE=false

REDIS_PORT=6379
REDIS_HOST=localhost
REDIS_PASSWORD=replace_me

S3_ACCESS_KEY_ID=replace_me
S3_SECRET_ACCESS_KEY=replace_me
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_BUCKET_NAME=dabucket
S3_PUBLIC_BASE_URL=http://127.0.0.1:9000/dabucket

NOTIFICATION_SERVICE_ORIGIN=http://127.0.0.1:3002
KAFKA_CLIENT_ID=notification
KAFKA_BROKERS=localhost:9092
KAFKA_CONSUMER_GROUP_ID=notification-consumer
